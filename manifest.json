{
  "manifest_version": 3,
  "name": "Media Link Scraper",
  "version": "1.0",
  "description": "Scrape video links,pictures link and create an url playlist",

  "icons": {
    "16": "icon16.png",
    "48": "icon48.png"
  },

  "permissions": [
    "downloads",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

    "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scrape.js"],
      "run_at": "document_idle"
    }
  ]
}
